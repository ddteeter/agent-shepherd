{
  "name": "agent-shepherd",
  "version": "0.1.0",
  "description": "Human-in-the-loop PR review tool for AI coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ddteeter/agent-shepherd.git"
  },
  "homepage": "https://github.com/ddteeter/agent-shepherd",
  "bugs": {
    "url": "https://github.com/ddteeter/agent-shepherd/issues"
  },
  "type": "module",
  "bin": {
    "agent-shepherd": "packages/cli/dist/index.js"
  },
  "files": [
    "packages/cli/dist/",
    "packages/backend/dist/",
    "packages/backend/drizzle/",
    "packages/frontend/dist/",
    "skills/"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=packages/backend\" \"npm run dev --workspace=packages/frontend\"",
    "build": "npm run build --workspace=packages/shared && npm run build --workspace=packages/backend --workspace=packages/frontend --workspace=packages/cli",
    "setup:dev": "npm run build && npm link && npm run link-skills",
    "link-skills": "for skill in skills/*/; do ln -sfn \"$(pwd)/$skill\" ~/.claude/skills/$(basename $skill); done",
    "teardown:dev": "npm unlink && for skill in skills/*/; do rm -f ~/.claude/skills/$(basename $skill); done",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "check:duplication": "jscpd ./packages --reporters console",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "better-sqlite3": "^12.6.2",
    "commander": "^14.0.3",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.7.4",
    "js-yaml": "^4.1.1",
    "node-notifier": "^10.0.1",
    "simple-git": "^3.32.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.1",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.56.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
